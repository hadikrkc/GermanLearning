// Prisma schema - Sprint 0 iskelet
// Tum modeller Sprint 1'den itibaren eklenecek (veritabani_semasi.txt referans).
// Bu dosya su an sadece generator + datasource + minimal marker icerir.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Sprint 0 marker - migration uretmek icin minimal model.
// Sprint 1'de User modeli eklenince bu kaldirilabilir.
model HealthCheck {
  id        String   @id @default(cuid())
  checkedAt DateTime @default(now())

  @@map("health_check")
}
