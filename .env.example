# Bu dosya her iki workspace icinde kullanilan ortak cevre degiskenlerini ornekler.
# Her workspace kendi .env dosyasini apps/api/.env ve apps/web/.env olarak tutar.
# Bu dosyanin bir kopyasini .env olarak kaydet ve gercek degerleri yaz.

# ----------- API -----------
NODE_ENV=development
API_PORT=3000

# Postgres baglantisi (her sey Docker'da oldugunda host.docker.internal kullanilir)
# Senaryo A: api Docker container'da (bizim varsayilan kurulum)
DATABASE_URL=postgresql://postgres:mysecretpassword@host.docker.internal:5432/almanca_dev?schema=public

# Senaryo B: api native calistiginda (pnpm dev api host'ta)
# DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/almanca_dev?schema=public

# JWT
JWT_ACCESS_SECRET=dev-access-secret-degistir
JWT_REFRESH_SECRET=dev-refresh-secret-degistir
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS
CORS_ORIGIN=http://localhost:5173

# Log
LOG_LEVEL=debug

# Storage (ilerleyen sprintlerde)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Seed admin (seed scripti bu bilgilerle admin olusturur)
SEED_ADMIN_EMAIL=admin@almanca.local
SEED_ADMIN_PASSWORD=admin12345

# ----------- WEB -----------
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Almanca Ogrenme
